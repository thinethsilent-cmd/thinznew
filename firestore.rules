rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the user is an admin
    function isAdmin() {
      return request.auth != null && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Helper function to check if user is accessing their own document
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Rules for Users collection
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin() || (request.auth != null && 'referredBy' in resource.data && resource.data.referredBy == request.auth.uid);
      
      // Allow creation if logged in and setting default values
      allow create: if request.auth != null && request.auth.uid == userId;
      
      // Allow update: 
      // 1. Owner can update their own details, but cannot self-approve premium or change role to admin.
      // 2. Admins can update anything.
      allow update: if isAdmin() || (
  isOwner(userId) &&
  request.resource.data.role == resource.data.role &&
  (request.resource.data.premiumStatus == resource.data.premiumStatus ||
   request.resource.data.premiumStatus == 'pending') &&
  // Allow adding/updating paymentSlipUrl during premium request
  (request.resource.data.paymentSlipUrl == resource.data.paymentSlipUrl ||
   (!('paymentSlipUrl' in resource.data) && request.resource.data.paymentSlipUrl is string))
);
    }

    // Rules for Signals collection
    match /signals/{signalId} {
      // Anyone logged in can read signals (we will handle the free/paid masking in front-end code)
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Rules for Trades collection
    match /trades/{tradeId} {
      // Users can only read and write their own auto-trades
      allow read, write: if request.auth != null && (request.resource.data.userId == request.auth.uid || resource.data.userId == request.auth.uid || isAdmin());
    }
  }
}
